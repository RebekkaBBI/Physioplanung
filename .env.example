# Next.js: Nur Variablen mit NEXT_PUBLIC_* sind im Browser verfügbar.
# Projekt in der EU-Region anlegen (Supabase Dashboard → Project Settings → Region).
# Nur die Root-URL: https://<ref>.supabase.co — ohne /rest/v1 oder /auth/v1
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Nur Server (lokal: .env.local; Vercel: ohne NEXT_PUBLIC_) — niemals ins Client-Bundle
# SUPABASE_SERVICE_ROLE_KEY=
# WORKSPACE_ADMIN_SECRET=

# Optional — YELLOW_AI
# NEXT_PUBLIC_AI_BASE_URL=
# NEXT_PUBLIC_AI_API_KEY=
# NEXT_PUBLIC_AI_MODEL=
